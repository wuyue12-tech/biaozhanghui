%%{init: {"theme": "base", "themeVariables": {"fontFamily": "Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif", "primaryColor": "#eef6ff", "primaryTextColor": "#102033", "primaryBorderColor": "#4b8bbe", "lineColor": "#5b6470"}}}%%
flowchart TD
  A(["前期共创<br/>学生提交真实挑战、行动改写、战队元素"]) --> B["任务包制作<br/>红袋信号卡<br/>蓝袋行动卡<br/>金袋支持卡<br/>行动牌/认证卡/路线卡"]
  B --> C["0-12 分钟 入场集结<br/>14支导师小队到战队区<br/>队长领取任务包<br/>主持发布一句规则"]

  C --> D["第一关 信号侦察接力<br/>6人接力取回6张信号碎片"]
  D --> E{"导师验收<br/>三类摆放<br/>每类说一句理由"}
  E -- "通过" --> F["解锁红袋<br/>选择1张正式信号卡<br/>贴入行动牌第一栏"]
  E -- "卡住" --> E1["现场口令<br/>按学习压力/时间管理/关系支持三类放好"]:::risk
  E1 --> E

  F --> G["第二关 行动补给传球<br/>10次传球<br/>至少7名队员触球"]
  G --> H{"导师验收<br/>10次传球<br/>7人触球<br/>行动三格写满"}
  H -- "通过" --> I["解锁蓝袋<br/>选择2张行动卡<br/>写清谁做/何时做/怎么检查"]
  H -- "卡住" --> H1["现场口令<br/>下一球传给未触球队员<br/>把行动补成三格"]:::risk
  H1 --> H

  I --> J["行动加压调整<br/>保留最重要一步<br/>写到能立刻执行"]
  J --> K["第三关 三方支援通道<br/>3名代表按路线卡出发"]
  K --> L["同伴支援<br/>补一句互助动作"]
  K --> M["家长支援<br/>补一句家庭支持"]
  K --> N["导师支援<br/>给出九年级支持入口"]
  L --> O{"导师验收<br/>三方支持齐全"}
  M --> O
  N --> O
  O -- "通过" --> P["解锁金袋<br/>选择并改写支持卡<br/>完成入境行动牌"]
  O -- "卡住" --> O1["现场口令<br/>只补一句支持<br/>学生带回队里完成"]:::risk
  O1 --> O

  P --> Q{"导师认证三问<br/>真实信号是什么<br/>两条行动是什么<br/>最需要哪种支持"}
  Q -- "通过" --> R["入境完成<br/>贴入境章<br/>入境墙<br/>荣誉点亮/合影"]:::done
  Q -- "卡住" --> Q1["现场补问<br/>答清楚再认证"]:::risk
  Q1 --> Q
  R --> S["活动后使用<br/>第一次导师谈话<br/>第一次家校沟通<br/>九年级准备清单"]:::done

  classDef risk fill:#fff1f2,stroke:#e11d48,color:#7f1d1d,stroke-width:2px;
  classDef done fill:#ecfdf5,stroke:#059669,color:#064e3b,stroke-width:2px;
